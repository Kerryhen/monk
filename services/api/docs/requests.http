# API Request Examples
# Compatible with REST Client (VS Code), IntelliJ HTTP Client, and curl.
# Replace BASE_URL and X-Instance-ID with your values.

@base_url = https://dev-listmonkapi.ailian.com.br
@instance_id = 4f0kfmefs6x09lo

###
# GET client info
GET {{base_url}}/v1/client
accept: application/json
x-instance-id: {{instance_id}}

###
# GET lists
GET {{base_url}}/v1/list/
accept: application/json
x-instance-id: {{instance_id}}

###
# CREATE list
POST {{base_url}}/v1/list/
accept: application/json
content-type: application/json
x-instance-id: {{instance_id}}

{
  "name": "My Subscribers",
  "type": "private",
  "optin": "single",
  "description": "Main subscriber list",
  "tags": ["newsletter"]
}

###
# GET campaigns
GET {{base_url}}/v1/campaign/
accept: application/json
x-instance-id: {{instance_id}}

###
# CREATE campaign (immediate)
POST {{base_url}}/v1/campaign/
accept: application/json
content-type: application/json
x-instance-id: {{instance_id}}

{
  "name": "dasd",
  "subject": "asdasdasd",
  "lists": [978],
  "from_email": null,
  "type": "regular",
  "content_type": "markdown",
  "body": "asdasdasdasd",
  "altbody": null,
  "send_later": false,
  "send_at": null,
  "messenger": "email",
  "tags": null
}

###
# CREATE campaign (scheduled)
POST {{base_url}}/v1/campaign/
accept: application/json
content-type: application/json
x-instance-id: {{instance_id}}

{
  "name": "Welcome Campaign",
  "subject": "Welcome to our newsletter!",
  "lists": [978],
  "from_email": "sender@example.com",
  "type": "regular",
  "content_type": "richtext",
  "body": "<p>Hello, welcome!</p>",
  "send_later": true,
  "send_at": "2026-04-01T10:00:00.000Z",
  "messenger": "email",
  "tags": ["welcome"]
}

###
# START campaign
# @prompt campaign_id Campaign ID
POST {{base_url}}/v1/campaign/{{campaign_id}}/start
accept: application/json
x-instance-id: {{instance_id}}

###
# STOP campaign
# @prompt campaign_id Campaign ID
POST {{base_url}}/v1/campaign/{{campaign_id}}/stop
accept: application/json
x-instance-id: {{instance_id}}

###
# DELETE campaign
# @prompt campaign_id Campaign ID
DELETE {{base_url}}/v1/campaign/{{campaign_id}}
accept: application/json
x-instance-id: {{instance_id}}

###
# IMPORT subscribers (JSON)
POST {{base_url}}/v1/subscriber/import/json
accept: application/json
content-type: application/json
x-instance-id: {{instance_id}}

[
  {"email": "subscriber@example.com", "name": "Jane Doe"}
]

###
# IMPORT subscribers (CSV)
POST {{base_url}}/v1/subscriber/import
accept: application/json
content-type: multipart/form-data; boundary=boundary
x-instance-id: {{instance_id}}

--boundary
Content-Disposition: form-data; name="file"; filename="subscribers.csv"
Content-Type: text/csv

email,name
subscriber@example.com,Jane Doe
--boundary--
